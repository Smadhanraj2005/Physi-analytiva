nd_position":"center right","background_slideshow_slide_transition":"slide_left","_flex_size":"none","_element_width":"initial","width_tablet":{"unit":"%","size":247.662},"width_mobile":{"unit":"%","size":114.072},"_element_width_mobile":"initial","_element_width_tablet":"initial"},"elements":[{"id":"596d788a","settings":{"html":"<!DOCTYPE html>\r\n<html lang=\"en\">\r\n<head>\r\n<meta charset=\"UTF-8\">\r\n<title>Contact Us<\/title>\r\n<\/head>\r\n\r\n<div style=\"width:100%; max-width:600px; background:#fff; padding:30px 40px; border-radius:15px; box-shadow:0 8px 20px rgba(0,0,0,0.1); box-sizing:border-box;\">\r\n\r\n    <form>\r\n\r\n        <label style=\"display:block; font-size:15px; font-weight:600; margin-bottom:8px; margin-top:20px; color:#0d1f3c;\">Email Address *<\/label>\r\n        <input type=\"email\" placeholder=\"Your email address\" required\r\n            style=\"width:100%; padding:16px 18px; border:1px solid #d0d4db; border-radius:10px; background:#fafafa; font-size:14px; box-sizing:border-box; transition:all 0.3s ease;\" \r\n            onfocus=\"this.style.borderColor='#0d6efd'; this.style.background='#fff'; this.style.boxShadow='0 4px 10px rgba(13,110,253,0.2)';\" \r\n            onblur=\"this.style.borderColor='#d0d4db'; this.style.background='#fafafa'; this.style.boxShadow='none';\">\r\n\r\n        <label style=\"display:block; font-size:15px; font-weight:600; margin-bottom:8px; margin-top:20px; color:#0d1f3c;\">Contact Number *<\/label>\r\n        <input type=\"tel\" placeholder=\"Your phone number\" required\r\n            style=\"width:100%; padding:16px 18px; border:1px solid #d0d4db; border-radius:10px; background:#fafafa; font-size:14px; box-sizing:border-box; transition:all 0.3s ease;\" \r\n            onfocus=\"this.style.borderColor='#0d6efd'; this.style.background='#fff'; this.style.boxShadow='0 4px 10px rgba(13,110,253,0.2)';\" \r\n            onblur=\"this.style.borderColor='#d0d4db'; this.style.background='#fafafa'; this.style.boxShadow='none';\">\r\n\r\n        <label style=\"display:block; font-size:15px; font-weight:600; margin-bottom:8px; margin-top:20px; color:#0d1f3c;\">Service Interested In *<\/label>\r\n        <select required\r\n            style=\"width:100%; padding:16px 18px; border:1px solid #d0d4db; border-radius:10px; background:#fafafa; font-size:14px; box-sizing:border-box; transition:all 0.3s ease;\"\r\n            onfocus=\"this.style.borderColor='#0d6efd'; this.style.background='#fff'; this.style.boxShadow='0 4px 10px rgba(13,110,253,0.2)';\" \r\n            onblur=\"this.style.borderColor='#d0d4db'; this.style.background='#fafafa'; this.style.boxShadow='none';\">\r\n            <option value=\"\">Select a service<\/option>\r\n            <option>Bio-Measurement<\/option>\r\n            <option>Physiological Monitoring<\/option>\r\n            <option>Lab Analysis<\/option>\r\n            <option>Consultation<\/option>\r\n            <option>Other<\/option>\r\n        <\/select>\r\n\r\n        <label style=\"display:block; font-size:15px; font-weight:600; margin-bottom:8px; margin-top:20px; color:#0d1f3c;\">Preferred Method of Contact<\/label>\r\n        <div style=\"display:flex; gap:20px; align-items:flex-start; margin-top:10px; flex-wrap:wrap;\">\r\n            <div style=\"flex:1; display:flex; gap:12px; flex-direction:column;\">\r\n                <label style=\"display:flex; align-items:center; gap:8px; cursor:pointer;\">\r\n                    <input type=\"radio\" name=\"contact\" value=\"Email\" onclick=\"showFollowUp(this)\" style=\"accent-color:#0d6efd; cursor:pointer; margin:0;\"> Email\r\n                <\/label>\r\n                <label style=\"display:flex; align-items:center; gap:8px; cursor:pointer;\">\r\n                    <input type=\"radio\" name=\"contact\" value=\"Phone\" onclick=\"showFollowUp(this)\" style=\"accent-color:#0d6efd; cursor:pointer; margin:0;\"> Phone\r\n                <\/label>\r\n            <\/div>\r\n            <div id=\"followUp\" style=\"flex:2; display:none; background:#f1f5fb; padding:12px 15px; border-left:4px solid #0d6efd; border-radius:6px; font-size:14px; color:#0d1f3c;\"><\/div>\r\n        <\/div>\r\n\r\n        <label style=\"display:block; font-size:15px; font-weight:600; margin-bottom:8px; margin-top:20px; color:#0d1f3c;\">Project \/ Requirement Details *<\/label>\r\n        <textarea placeholder=\"Describe your project or what you need assistance with\" required\r\n            style=\"width:100%; padding:16px 18px; border:1px solid #d0d4db; border-radius:10px; background:#fafafa; font-size:14px; min-height:160px; resize:vertical; box-sizing:border-box; transition:all 0.3s ease;\" \r\n            onfocus=\"this.style.borderColor='#0d6efd'; this.style.background='#fff'; this.style.boxShadow='0 4px 10px rgba(13,110,253,0.2)';\" \r\n            onblur=\"this.style.borderColor='#d0d4db'; this.style.background='#fafafa'; this.style.boxShadow='none';\"><\/textarea>\r\n\r\n        <button type=\"submit\" \r\n            style=\"display:block; width:100%; margin-top:35px; padding:16px; background:#0d6efd; color:#fff; border:none; border-radius:12px; font-size:16px; font-weight:600; cursor:pointer; letter-spacing:1px; transition:all 0.3s ease;\"\r\n            onmouseover=\"this.style.background='#0058d3'; this.style.transform='scale(1.02)';\"\r\n            onmouseout=\"this.style.background='#0d6efd'; this.style.transform='scale(1)';\">\r\n            Send Inquiry\r\n        <\/button>\r\n\r\n    <\/form>\r\n\r\n<\/div>\r\n\r\n<script>\r\nfunction showFollowUp(radio) {\r\n    const followUp = document.getElementById('followUp');\r\n    followUp.style.display = 'block';\r\n    if(radio.value === 'Email') {\r\n        followUp.innerHTML = 'Please ensure your email address is active; we will send confirmation and updates there.';\r\n    } else if(radio.value === 'Phone') {\r\n        followUp.innerHTML = 'Our team will call you. Please provide a reachable phone number.';\r\n    }\r\n}\r\n<\/script>\r\n\r\n<\/body>\r\n<\/html>\r\n","_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":true},"_padding_mobile":{"unit":"px","top":"20","right":"20","bottom":"20","left":"20","isLinked":true}},"elements":[],"isInner":false,"widgetType":"html","elType":"widget"}],"isInner":true,"elType":"container"}],"isInner":true,"elType":"container"}],"isInner":false,"elType":"container"}],"page_settings":{"hide_title":"yes","background_background":"classic","background_color":"#ffffff","astra_sites_main_color":"var(--ast-global-color-0)","astra_sites_heading_base_color":"var(--ast-global-color-2)","astra_sites_link_color":"var(--ast-global-color-1)","astra_sites_link_hover_color":"var(--ast-global-color-1)","astra_sites_text_color":"var(--ast-global-color-3)","astra_sites_body_typography":"custom","astra_sites_body_font_size":{"unit":"px","size":16},"astra_sites_body_line_height":{"unit":"em","size":1.6},"astra_sites_body_font_family":"Open Sans","astra_sites_body_font_weight":"400","astra_sites_heading_1_typography":"custom","astra_sites_heading_1_font_size":{"unit":"px","size":48},"astra_sites_heading_1_font_size_tablet":{"unit":"px","size":40},"astra_sites_heading_1_font_size_mobile":{"unit":"px","size":28},"astra_sites_heading_1_line_height":{"unit":"em","size":1.2},"astra_sites_default_heading_font_family":"'Poppins', sans-serif","astra_sites_heading_1_font_family":"'Poppins'","astra_sites_heading_1_font_weight":"normal","astra_sites_heading_2_typography":"custom","astra_sites_heading_2_font_size":{"unit":"px","size":42},"astra_sites_heading_2_font_size_tablet":{"unit":"px","size":35},"astra_sites_heading_2_font_size_mobile":{"unit":"px","size":24},"astra_sites_heading_2_font_family":"'Poppins'","astra_sites_heading_2_font_weight":"700","astra_sites_heading_3_typography":"custom","astra_sites_heading_3_font_size":{"unit":"px","size":28},"astra_sites_heading_3_font_size_tablet":{"unit":"px","size":24},"astra_sites_heading_3_font_si